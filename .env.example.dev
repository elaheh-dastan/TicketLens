# Environment variables for the General Agent Framework
# Copy this file to .env and fill in your actual API keys

# Core Configuration
ENVIRONMENT=development
DEBUG=true

# OpenRouter Configuration
LLMS__OPENROUTER_API_KEY=your-openrouter-api-key-here

# Redis Configuration
REDIS__HOST=localhost
REDIS__PORT=6379
REDIS__PASSWORD=
REDIS__DB=0

# PostgreSQL Configuration
POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__USER=agent
POSTGRES__PASSWORD=agentpass
POSTGRES__DATABASE=agentdb

# Qdrant Configuration
QDRANT__HOST=localhost
QDRANT__PORT=6333
QDRANT__API_KEY=

# Serper (Google Search) Configuration
SERPER_API_KEY=your-serper-api-key-here

# Tavily (Web Search) Configuration
TAVILY_API_KEY=your-tavily-api-key-here

# Firecrawl Configuration
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# Playwright MCP Configuration
PLAYWRIGHT_MCP_ENDPOINT=http://localhost:8000

# Kafka Configuration
KAFKA__ENABLED=true
KAFKA__BOOTSTRAP_SERVERS=localhost:9092
KAFKA__RESULTS_TOPIC=agent-results
KAFKA__STATUS_TOPIC=agent-status
KAFKA__PUBLISH_RESULTS=true
KAFKA__CONSUMER_GROUP=agent-framework
KAFKA__PRODUCER_ACKS=all
KAFKA__PRODUCER_RETRIES=3
KAFKA__PRODUCER_COMPRESSION_TYPE=snappy

# Langfuse Observability Configuration
# Get your keys from https://cloud.langfuse.com
LANGFUSE__ENABLED=false
LANGFUSE__SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE__PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE__HOST=https://cloud.langfuse.com
LANGFUSE__RELEASE=1.0.0
LANGFUSE__DEBUG=false
LANGFUSE__SAMPLE_RATE=1.0
LANGFUSE__TIMEOUT=10

KAFKA__SERIALIZATION_FORMAT=avro
